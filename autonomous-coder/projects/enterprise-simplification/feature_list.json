    {
      "id": "WEB-001",
      "category": "webapp-p0",
      "priority": "critical",
      "description": "TTFT 计时器锁定测试",
      "detailed_description": "验证 TTFT 在首 token 输出后正确锁定，使用 Chrome DevTools Network 面板验证",
      "test_method": "Chrome DevTools",
      "test_env": {
        "frontend": "http://localhost:5174",
        "devtools": "Network → EventStream"
      },
      "steps": [
        {"step": 1, "action": "打开 Chrome DevTools → Network 标签"},
        {"step": 2, "action": "发送消息 '帮我查查今天天气'"},
        {"step": 3, "action": "等待首 token，记录 TTFT 值（如 0.85s）"},
        {"step": 4, "action": "等待后续步骤执行"},
        {"step": 5, "action": "验证 TTFT 仍为 0.85s（不变）"},
        {"step": 6, "action": "在 Network → EventStream 中验证首个 text_delta 时间戳"}
      ],
      "verification": {
        "ui_check": "TTFT 显示值在后续步骤执行期间不变",
        "network_check": "TTFT = text_delta时间 - 请求发起时间，与界面显示一致"
      },
      "files_affected": ["webapps/seeagent-webui/src/components/Timer/ElapsedTimer.tsx"],
      "passes": false
    },
